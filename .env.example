# IBKR Configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497 = paper trading, 7496 = live trading
IBKR_CLIENT_ID=1        # Unique client ID per connection

# Trading Configuration
PAPER_TRADING=true

# Risk Management
STOP_LOSS_PERCENT=1.0
TRAILING_STOP_PERCENT=2.0
MAX_POSITION_SIZE_PERCENT=1.0  # 1% rule
MAX_POSITIONS=8
MAX_TOTAL_RISK_PERCENT=10.0  # Total risk across all positions

# Circuit Breaker
MAX_DAILY_LOSS_PERCENT=2.0  # Stop trading if daily loss hits 2%
MAX_DRAWDOWN_PERCENT=5.0  # Overall account drawdown limit

# ATR-Based Stops
ATR_PERIOD=14
ATR_STOP_MULTIPLIER=2.0  # Stop loss = entry - (2 * ATR)
ATR_TARGET_MULTIPLIER=3.0  # Take profit = entry + (3 * ATR)

# Diversification
MAX_POSITIONS_PER_SECTOR=2
MAX_CORRELATION=0.6  # Max correlation between positions

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/trading_bot.log
