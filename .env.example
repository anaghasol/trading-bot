# IBKR Configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497 = paper trading, 7496 = live trading
IBKR_CLIENT_ID=1        # Unique client ID per connection

# Trading Configuration
PAPER_TRADING=true

# Risk Management
STOP_LOSS_PERCENT=1.0
TRAILING_STOP_PERCENT=2.0
MAX_POSITION_SIZE_PERCENT=1.0  # 1% rule
MAX_POSITIONS=8
MAX_TOTAL_RISK_PERCENT=10.0  # Total risk across all positions

# Circuit Breaker
MAX_DAILY_LOSS_PERCENT=2.0  # Stop trading if daily loss hits 2%
MAX_DRAWDOWN_PERCENT=5.0  # Overall account drawdown limit

# ATR-Based Stops
ATR_PERIOD=14
ATR_STOP_MULTIPLIER=2.0  # Stop loss = entry - (2 * ATR)
ATR_TARGET_MULTIPLIER=3.0  # Take profit = entry + (3 * ATR)

# Diversification
MAX_POSITIONS_PER_SECTOR=2
MAX_CORRELATION=0.6  # Max correlation between positions

# Volume/Volatility Filters
MIN_VOLUME_MULTIPLIER=2.0  # Require 2x average volume
MIN_ATR_PERCENTILE=0.5  # Only trade stocks with ATR > median

# Alert Escalation
ALERT_EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
ALERT_SENDER_EMAIL=your-email@gmail.com
ALERT_SENDER_PASSWORD=your-app-password
ALERT_RECIPIENT_EMAIL=your-email@gmail.com
ALERT_SMS_EMAIL=1234567890@txt.att.net  # SMS via email gateway

# Backtesting
BACKTEST_SLIPPAGE_PCT=0.1  # 0.1% slippage per trade
BACKTEST_COMMISSION=1.0  # $1 per trade
MIN_SHARPE_RATIO=1.2  # Require Sharpe > 1.2 post-fees

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/trading_bot.log
